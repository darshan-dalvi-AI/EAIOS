# ── EAIOS configuration ─────────────────────────────────────────
# Copy to .env and adjust. Every value has a safe default; the app
# runs with zero external services (SQLite + in-memory vectors + mock LLM).

SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database — leave unset for SQLite dev fallback (./eaios.db)
# DATABASE_URL=postgresql+psycopg2://eaios:eaios_dev_password@localhost:5432/eaios

# Vector store — leave unset for in-memory fallback
# QDRANT_URL=http://localhost:6333

# Redis (rate limiting / task queue) — optional
# REDIS_URL=redis://localhost:6379/0

# ── LLM layer ────────────────────────────────────────────────────
# mock | ollama | openai | anthropic
LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Embeddings: hash (zero-dep dev) | ollama | sentence-transformers
EMBEDDING_PROVIDER=auto
EMBEDDING_DIM=384

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
UPLOAD_DIR=./uploads

# ── Observability (optional) ─────────────────────────────────────
# Traces are always available in the Traces app (in-process buffer).
# Mirror them to external dashboards by configuring either exporter:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # + pip install opentelemetry-sdk opentelemetry-exporter-otlp
# LANGFUSE_PUBLIC_KEY=pk-...                          # + pip install langfuse
# LANGFUSE_SECRET_KEY=sk-...
